# Porta do servidor
PORT=3000

# Rota única para receber webhooks (ex: /xK9mP2qR7nLs).
# Se omitida, uma rota aleatória é gerada cada vez que o servidor inicia.
# WEBHOOK_PATH=/minha-rota-secreta

# URL pública do túnel (ngrok, etc.) — sem barra no final.
# Quando definida, o servidor exibe a URL completa do webhook ao iniciar.
# PUBLIC_URL=https://seu-subdominio.ngrok-free.dev

# Liga/desliga a verificação de assinatura. Padrão: ativada.
# Defina como false para aceitar webhooks sem verificar (dev / provedores sem assinatura).
VERIFY_SIGNATURE=true

# Segredo compartilhado com o SEU servidor. Use um valor longo e aleatório.
# Gere um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=troque-por-um-segredo-forte

# Nome do header onde o servidor de origem envia a assinatura HMAC.
# Exemplos comuns: x-signature, x-hub-signature-256, x-webhook-signature
SIGNATURE_HEADER=x-signature

# --- Armazenamento (Redis / Upstash) ---
# OBRIGATÓRIO em serverless (Vercel), pois a memória não é compartilhada entre
# invocações. Em desenvolvimento local, se estas variáveis estiverem ausentes,
# o servidor cai automaticamente para armazenamento em memória.
# Crie um banco em https://upstash.com (ou via integração Vercel > Storage) e cole:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxx
# (a integração Redis da Vercel também define KV_REST_API_URL / KV_REST_API_TOKEN,
#  que são aceitos como alternativa)
